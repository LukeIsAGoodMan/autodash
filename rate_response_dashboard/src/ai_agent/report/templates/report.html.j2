<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ pkg.config_snapshot.report_title or "Rate Response Dashboard" }} — Monthly Report</title>
<style>
  :root {
    --primary: #1a4d8c;
    --accent: #4a7bb7;
    --good: #2e7a52;
    --warn: #c98a25;
    --bad: #b3434a;
    --ink: #1f2933;
    --muted: #5a6573;
    --line: #e1e4e8;
    --bg: #f7f8fa;
    --card: #ffffff;
  }
  * { box-sizing: border-box; }
  body {
    font-family: "Segoe UI", -apple-system, BlinkMacSystemFont, Helvetica, Arial, sans-serif;
    color: var(--ink);
    background: var(--bg);
    margin: 0;
    padding: 32px;
    font-size: 14px;
    line-height: 1.5;
  }
  .container { max-width: 1200px; margin: 0 auto; }
  header {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white;
    padding: 28px 32px;
    border-radius: 8px;
    margin-bottom: 24px;
  }
  header h1 { margin: 0; font-size: 24px; font-weight: 600; }
  header .subtitle { margin-top: 6px; font-size: 13px; opacity: 0.9; }
  header .watermark {
    display: inline-block;
    margin-top: 12px;
    padding: 4px 10px;
    background: rgba(255,255,255,0.18);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 4px;
    font-size: 12px;
    letter-spacing: 0.3px;
  }
  section {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 22px 26px;
    margin-bottom: 18px;
  }
  section h2 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 14px 0;
    color: var(--primary);
    border-bottom: 2px solid var(--primary);
    padding-bottom: 6px;
    display: inline-block;
  }
  section h3 {
    font-size: 14px;
    font-weight: 600;
    margin: 18px 0 8px 0;
    color: var(--ink);
  }
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 12px;
    margin-top: 6px;
  }
  .kpi {
    border: 1px solid var(--line);
    border-top: 3px solid var(--primary);
    border-radius: 6px;
    padding: 12px 14px;
    background: var(--card);
  }
  .kpi .k-label { font-size: 12px; color: var(--muted); }
  .kpi .k-value { font-size: 22px; font-weight: 600; margin-top: 4px; color: var(--ink); }
  table {
    border-collapse: collapse;
    width: 100%;
    font-size: 13px;
  }
  th, td {
    text-align: right;
    padding: 8px 10px;
    border-bottom: 1px solid var(--line);
  }
  th:first-child, td:first-child { text-align: left; }
  thead th {
    background: #f0f2f5;
    color: var(--ink);
    font-weight: 600;
    border-bottom: 1px solid var(--line);
  }
  tbody tr:nth-child(odd) { background: #fafbfd; }
  .chip {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.2px;
  }
  .dir-up   { background: #e7f4ec; color: var(--good); }
  .dir-down { background: #fbeceb; color: var(--bad);  }
  .dir-flat { background: #eef0f3; color: var(--muted); }
  .mat-full    { background: #e7f4ec; color: var(--good); }
  .mat-partial { background: #fcf2e3; color: var(--warn); }
  .mat-unknown { background: #eef0f3; color: var(--muted); }
  .na { color: var(--muted); font-style: italic; }
  .note {
    background: #fbf9f2;
    border-left: 3px solid var(--warn);
    padding: 10px 14px;
    color: var(--muted);
    font-size: 12.5px;
    margin-top: 10px;
  }
  .twocol { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  @media (max-width: 760px) { .twocol { grid-template-columns: 1fr; } }
  footer { text-align: center; font-size: 12px; color: var(--muted); margin-top: 20px; }
</style>
</head>
<body>
<div class="container">

  {# ------------------------------------------------------------ HEADER #}
  <header>
    <h1>{{ pkg.config_snapshot.report_title or "Rate Response Dashboard" }}</h1>
    <div class="subtitle">
      Monthly report — latest month
      <strong>{{ pkg.facts.latest_month or "n/a" }}</strong>
      &middot; generated {{ pkg.facts.generated_at }}
    </div>
    <span class="watermark">AI-generated draft &middot; analyst review required</span>
  </header>

  {# ------------------------------------------------------------ MATURITY #}
  {% set latest_mat = pkg.facts.maturity.get(pkg.facts.latest_month) %}
  <section>
    <h2>Data quality &amp; maturity</h2>
    <p>
      Latest month
      <strong>{{ pkg.facts.latest_month }}</strong>
      maturity:
      {% if latest_mat %}
        <span class="chip {{ latest_mat.status | maturity_class }}">{{ latest_mat.status }}</span>
        &middot; XPM data:
        {% if latest_mat.has_xpm %}
          <span class="chip mat-full">available</span>
        {% else %}
          <span class="chip mat-partial">unavailable</span>
        {% endif %}
      {% else %}
        <span class="chip mat-unknown">unknown</span>
      {% endif %}
    </p>
    {% set immature = [] %}
    {% for cm, info in pkg.facts.maturity.items() %}
      {% if info.status != 'full' %}{% set _ = immature.append(cm) %}{% endif %}
    {% endfor %}
    {% if immature %}
    <div class="note">
      <strong>{{ immature | length }}</strong> month(s) not yet fully matured —
      response window still open. Treat NRR / board rate for these months as
      preliminary, not final: {{ immature | join(", ") }}.
    </div>
    {% endif %}
  </section>

  {# ------------------------------------------------------------ LATEST KPIs #}
  {% set overall_latest = none %}
  {% for r in pkg.facts.overall_trend %}
    {% if r.campaign_month == pkg.facts.latest_month %}{% set overall_latest = r %}{% endif %}
  {% endfor %}
  <section>
    <h2>Latest month KPIs (overall)</h2>
    {% if overall_latest %}
    <div class="kpi-grid">
      <div class="kpi"><div class="k-label">Mail volume</div>
        <div class="k-value">{{ overall_latest.volume | intk }}</div></div>
      <div class="kpi"><div class="k-label">Responders</div>
        <div class="k-value">{{ overall_latest.responders | intk }}</div></div>
      <div class="kpi"><div class="k-label">Boards</div>
        <div class="k-value">{{ overall_latest.boards | intk }}</div></div>
      <div class="kpi"><div class="k-label">Net response rate</div>
        <div class="k-value">{{ overall_latest.nrr | pct }}</div></div>
      <div class="kpi"><div class="k-label">Board rate</div>
        <div class="k-value">{{ overall_latest.board_rate | pct }}</div></div>
      <div class="kpi"><div class="k-label">Actual / Expected (TRM)</div>
        <div class="k-value">{{ overall_latest.ae_trm | ratio }}</div></div>
      <div class="kpi"><div class="k-label">Actual / Expected (XPM)</div>
        <div class="k-value">{{ overall_latest.ae_xpm | ratio }}</div></div>
    </div>
    {% else %}
    <p class="na">No data for latest month.</p>
    {% endif %}
  </section>

  {# ------------------------------------------------------------ OVERALL MoM / YoY #}
  <section>
    <h2>Overall MoM &amp; YoY</h2>
    {% macro mov_row(movs, label) %}
      <h3>{{ label }}</h3>
      {% if movs %}
      <table>
        <thead><tr>
          <th>Metric</th><th>Current</th><th>Prior</th><th>Δ</th><th>Direction</th>
        </tr></thead>
        <tbody>
        {% for m in movs %}
        <tr>
          <td>{{ m.metric }}</td>
          <td>
            {% if m.metric in ['nrr', 'board_rate'] %}{{ m.current_value | pct }}
            {% else %}{{ m.current_value | intk }}{% endif %}
          </td>
          <td>
            {% if m.metric in ['nrr', 'board_rate'] %}{{ m.prior_value | pct }}
            {% else %}{{ m.prior_value | intk }}{% endif %}
          </td>
          <td>
            {% if m.metric in ['nrr', 'board_rate'] %}{{ m.delta_bps | bps }}
            {% else %}{{ m.delta_pct | pct_change }}{% endif %}
          </td>
          <td><span class="chip {{ m.direction | direction_class }}">{{ m.direction }}</span></td>
        </tr>
        {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p class="na">No prior-month or YoY anchor available.</p>
      {% endif %}
    {% endmacro %}

    <div class="twocol">
      <div>{{ mov_row(pkg.mom_yoy.overall_mom, "Month over Month") }}</div>
      <div>{{ mov_row(pkg.mom_yoy.overall_yoy, "Year over Year") }}</div>
    </div>
  </section>

  {# ------------------------------------------------------------ PRODUCT #}
  <section>
    <h2>By product (annual_fee)</h2>
    {% set rate_movs = pkg.mom_yoy.product_mom | selectattr('metric', 'equalto', 'nrr') | list %}
    {% if rate_movs %}
    <table>
      <thead><tr>
        <th>Product</th><th>NRR (latest)</th><th>NRR (prior)</th>
        <th>MoM Δ</th><th>Direction</th>
      </tr></thead>
      <tbody>
      {% for m in rate_movs %}
      <tr>
        <td>{{ m.dim_value | dash_if_none }}</td>
        <td>{{ m.current_value | pct }}</td>
        <td>{{ m.prior_value | pct }}</td>
        <td>{{ m.delta_bps | bps }}</td>
        <td><span class="chip {{ m.direction | direction_class }}">{{ m.direction }}</span></td>
      </tr>
      {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p class="na">No product-level MoM available.</p>
    {% endif %}
  </section>

  {# ------------------------------------------------------------ BIGGEST MOVERS #}
  <section>
    <h2>Biggest segment NRR movers (MoM)</h2>
    {% if pkg.mom_yoy.biggest_movers %}
    <table>
      <thead><tr>
        <th>Dim</th><th>Value</th><th>NRR (latest)</th>
        <th>NRR (prior)</th><th>Δ</th><th>Direction</th>
      </tr></thead>
      <tbody>
      {% for m in pkg.mom_yoy.biggest_movers %}
      <tr>
        <td>{{ m.dim }}</td>
        <td>{{ m.dim_value | dash_if_none }}</td>
        <td>{{ m.current_value | pct }}</td>
        <td>{{ m.prior_value | pct }}</td>
        <td>{{ m.delta_bps | bps }}</td>
        <td><span class="chip {{ m.direction | direction_class }}">{{ m.direction }}</span></td>
      </tr>
      {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p class="na">No segment movers (no prior month or all suppressed by small-cell rule).</p>
    {% endif %}
  </section>

  {# ------------------------------------------------------------ MODEL #}
  <section>
    <h2>Model performance &amp; strategic choice</h2>

    <h3>Headline rank-order ({{ pkg.model.latest_month }})</h3>
    <table>
      <thead><tr>
        <th>Model</th><th>Scope</th><th>KS</th><th>AUC</th>
        <th>Gini</th><th>Top-decile lift</th><th>Misrank rows</th>
      </tr></thead>
      <tbody>
      {% for s in pkg.model.headline %}
      <tr>
        <td>{{ s.model }}</td>
        <td>{{ s.scope }}</td>
        {% if s.available %}
          <td>{{ "%.3f" | format(s.ks) if s.ks is not none else "—" }}</td>
          <td>{{ "%.3f" | format(s.auc) if s.auc is not none else "—" }}</td>
          <td>{{ "%.3f" | format(s.gini) if s.gini is not none else "—" }}</td>
          <td>{{ s.top_decile_lift | ratio }}</td>
          <td>{{ s.misrank_count if s.misrank_count is not none else "—" }}</td>
        {% else %}
          <td colspan="5" class="na">{{ s.note }}</td>
        {% endif %}
      </tr>
      {% endfor %}
      </tbody>
    </table>

    <h3>Calibration trend — A/E ratio by month</h3>
    {# Wide-form table: rows = month, columns = TRM A/E, XPM A/E #}
    {% set cal_by_month = {} %}
    {% for c in pkg.model.calibration_trend %}
      {% if c.campaign_month not in cal_by_month %}{% set _ = cal_by_month.update({c.campaign_month: {}}) %}{% endif %}
      {% set _ = cal_by_month[c.campaign_month].update({c.model: c}) %}
    {% endfor %}
    <table>
      <thead><tr>
        <th>Month</th><th>TRM A/E</th><th>XPM A/E</th><th>Maturity</th>
      </tr></thead>
      <tbody>
      {% for cm in pkg.facts.months_in_scope %}
        {% set pair = cal_by_month.get(cm, {}) %}
        {% set trm = pair.get('TRM') %}
        {% set xpm = pair.get('XPM') %}
        {% set mat = pkg.facts.maturity.get(cm) %}
        <tr>
          <td>{{ cm }}</td>
          <td>
            {% if trm and trm.available %}{{ trm.ae_ratio | ratio }}
            {% else %}<span class="na">—</span>{% endif %}
          </td>
          <td>
            {% if xpm and xpm.available %}{{ xpm.ae_ratio | ratio }}
            {% else %}<span class="na">—</span>{% endif %}
          </td>
          <td>
            {% if mat %}<span class="chip {{ mat.status | maturity_class }}">{{ mat.status }}</span>
            {% else %}<span class="na">unknown</span>{% endif %}
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
    {% if pkg.model.swap_estimate is none %}
    <div class="note">
      Strategic swap estimate (replace TRM10 with XPM07 under same volume/board target)
      is reserved for a future iteration once SAS emits an XPM-binned decile mart.
    </div>
    {% endif %}
  </section>

  {# ------------------------------------------------------------ APPENDIX #}
  <section>
    <h2>Appendix &middot; months in scope</h2>
    <p>{{ pkg.facts.months_in_scope | length }} months: {{ pkg.facts.months_in_scope | join(", ") }}</p>
    <p style="color: var(--muted); font-size: 12px;">
      Small-cell threshold: {{ pkg.config_snapshot.small_cell_threshold }} &middot;
      Maturity threshold: {{ pkg.config_snapshot.maturity_threshold_months }} months.
    </p>
  </section>

  <footer>
    Rate Response Dashboard — AI Report Generator &middot; Stage 1 (deterministic, no LLM)
  </footer>
</div>
</body>
</html>
